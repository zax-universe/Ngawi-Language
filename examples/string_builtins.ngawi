fn main() -> amba {
  muwani s: imut = "  NgawiLang  ";
  muwani t: imut = trim(s);
  muwani c: fuad = contains(t, "awi");
  muwani p: fuad = starts_with(t, "Nga");
  muwani e: fuad = ends_with(t, "Lang");
  muwani low: imut = to_lower(t);
  muwani up: imut = to_upper(t);
  print(c, p, e, low, up);
  return 0;
}

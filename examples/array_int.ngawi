fn main() -> amba {
  muwani a: amba[] = [10, 20, 30];
  muwani f: rusdi[] = [1.5, 2.5];
  muwani b: fuad[] = [true, false];
  muwani s: imut[] = ["aa", "bb"];

  a = push(a, 40);
  a = pop(a);
  s = push(s, "cc");

  a[1] = 99;

  muwani x: amba = a[1];
  muwani y: rusdi = f[0];
  muwani z: fuad = b[1];
  muwani t: imut = s[2];
  muwani n: amba = len(a);

  print(x, y, z, t, n);
  return 0;
}
